{
  "info": {
    "name": "PulseBox API",
    "description": "Complete API test collection for PulseBox multi-tenant HR platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://your-domain.com/api",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. User Auth - Get Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/user-token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "user-token"
              ]
            },
            "description": "Exchange user credentials for access token. Copy the access_token to the user_token variable."
          },
          "response": []
        },
        {
          "name": "2. App Auth - Get Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"app_id\": \"{{app_id}}\",\n  \"app_secret\": \"{{app_secret}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "token"
              ]
            },
            "description": "Exchange app credentials for JWT token. Copy the access_token to the app_token variable."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Collections (User Auth)",
      "description": "Collection management endpoints - requires user token and X-Tenant-Id header",
      "item": [
        {
          "name": "List Collections",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenant_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/collections?type=all",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "collections"
              ],
              "query": [
                {
                  "key": "type",
                  "value": "all"
                }
              ]
            },
            "description": "List all collections in the tenant"
          },
          "response": []
        },
        {
          "name": "Get Collection Schema",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenant_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/collections/employees",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "collections",
                "employees"
              ]
            },
            "description": "Get schema and fields for a specific collection. Replace 'employees' with your collection slug."
          },
          "response": []
        },
        {
          "name": "Create Collection",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"test-collection\",\n  \"name\": \"Test Collection\",\n  \"description\": \"A test collection for API testing\",\n  \"fields\": [\n    {\n      \"slug\": \"name\",\n      \"type\": \"text\",\n      \"label\": \"Name\",\n      \"required\": true\n    },\n    {\n      \"slug\": \"email\",\n      \"type\": \"email\",\n      \"label\": \"Email\",\n      \"required\": false\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/collections",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "collections"
              ]
            },
            "description": "Create a new collection with initial fields"
          },
          "response": []
        },
        {
          "name": "Update Collection",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Collection Name\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/collections/test-collection",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "collections",
                "test-collection"
              ]
            },
            "description": "Update collection metadata. Replace 'test-collection' with your collection slug."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Items - User Auth",
      "description": "Item management endpoints - requires user token and X-Tenant-Id header",
      "item": [
        {
          "name": "List Items",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenant_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/collections/employees/items?page=1&limit=20",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "collections",
                "employees",
                "items"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "List items in a collection with pagination. Replace 'employees' with your collection slug."
          },
          "response": []
        },
        {
          "name": "Get Item",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenant_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/collections/employees/items/item-id-here",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "collections",
                "employees",
                "items",
                "item-id-here"
              ]
            },
            "description": "Get a specific item. Replace 'item-id-here' with an actual item ID."
          },
          "response": []
        },
        {
          "name": "Create Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/collections/employees/items",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "collections",
                "employees",
                "items"
              ]
            },
            "description": "Create a new item in the collection"
          },
          "response": []
        },
        {
          "name": "Create Item with Translations",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"code\": \"HR\",\n    \"name\": \"Human Resources\"\n  },\n  \"translations\": {\n    \"zh-CN\": {\n      \"name\": \"人力资源\"\n    },\n    \"ms\": {\n      \"name\": \"Sumber Manusia\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/collections/employees/items",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "collections",
                "employees",
                "items"
              ]
            },
            "description": "Create an item with multi-language translations"
          },
          "response": []
        },
        {
          "name": "Update Item",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenant_id}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"name\": \"Jane Doe\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/collections/employees/items/item-id-here",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "collections",
                "employees",
                "items",
                "item-id-here"
              ]
            },
            "description": "Update an existing item. Replace 'item-id-here' with actual item ID."
          },
          "response": []
        },
        {
          "name": "Delete Item",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenant_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/collections/employees/items/item-id-here",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "collections",
                "employees",
                "items",
                "item-id-here"
              ]
            },
            "description": "Delete an item permanently. Replace 'item-id-here' with actual item ID."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Items - App Auth",
      "description": "Item endpoints using app token (no X-Tenant-Id needed - tenant embedded in token)",
      "item": [
        {
          "name": "List Items (App Token)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{app_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/collections/employees/items?page=1&limit=20",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "collections",
                "employees",
                "items"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "List items using app token (server-to-server)"
          },
          "response": []
        },
        {
          "name": "Create Item (App Token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{app_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"name\": \"API Created Item\",\n    \"email\": \"api@example.com\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/collections/employees/items",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "collections",
                "employees",
                "items"
              ]
            },
            "description": "Create item using app token for server-to-server integration"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Content Catalogs",
      "description": "Content catalog endpoints for shared content management",
      "item": [
        {
          "name": "List Content Catalogs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenant_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/content-catalogs",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "content-catalogs"
              ]
            },
            "description": "List all available content catalogs"
          },
          "response": []
        },
        {
          "name": "Get Catalog Items",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              },
              {
                "key": "X-Tenant-Id",
                "value": "{{tenant_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/content-catalogs/countries",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "content-catalogs",
                "countries"
              ]
            },
            "description": "Get items from a specific catalog. Replace 'countries' with actual catalog slug."
          },
          "response": []
        }
      ]
    }
  ]
}
